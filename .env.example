COMPOSE_PROJECT_NAME=enterprise-microservices-base-lite
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Public HTTP ports
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8085
CATALOG_SERVICE_PORT=7201
ORDERING_SERVICE_PORT=7203

# Database ports
CATALOG_DB_PORT=14330
ORDERING_DB_PORT=14331

# Shared credentials
SQL_SA_PASSWORD=Your_password123
JWT_ISSUER=https://auth.local
JWT_AUDIENCE=gateway-api
JWT_SIGNING_KEY=gateway-signing-key-1234567890123456
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
GATEWAY_CLIENT_ID=gateway-client
GATEWAY_CLIENT_SECRET=gateway-secret

# Connection strings used by containers
CATALOG_DB_CONNECTION_STRING=Server=catalog-db,1433;Database=CatalogDb;User Id=sa;Password=Your_password123;TrustServerCertificate=true
ORDERING_DB_CONNECTION_STRING=Server=ordering-db,1433;Database=OrderingDb;User Id=sa;Password=Your_password123;TrustServerCertificate=true

# Internal service URLs
CATALOG_API_INTERNAL_URL=http://catalog-service-api:8080/
ORDERING_API_INTERNAL_URL=http://ordering-service-api:8080/
