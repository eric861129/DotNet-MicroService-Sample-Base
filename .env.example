# Local development environment sample
# Copy this file to .env if you want a custom local setup.

COMPOSE_PROJECT_NAME=enterprise-microservices
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Public HTTP ports
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8085
CATALOG_SERVICE_PORT=7201
INVENTORY_SERVICE_PORT=7202
ORDERING_SERVICE_PORT=7203
NOTIFICATION_SERVICE_PORT=7204

# Infrastructure ports
CATALOG_DB_PORT=14330
ORDERING_DB_PORT=14331
INVENTORY_DB_PORT=14332
NOTIFICATION_DB_PORT=14333
AUTH_DB_PORT=14334
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
GRAFANA_PORT=3000

# Shared local credentials
SQL_SA_PASSWORD=Your_password123
RABBITMQ_HOST=rabbitmq
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Connection strings used by containers
CATALOG_DB_CONNECTION_STRING=Server=catalog-db,1433;Database=CatalogDb;User Id=sa;Password=Your_password123;TrustServerCertificate=true
ORDERING_DB_CONNECTION_STRING=Server=ordering-db,1433;Database=OrderingDb;User Id=sa;Password=Your_password123;TrustServerCertificate=true
INVENTORY_DB_CONNECTION_STRING=Server=inventory-db,1433;Database=InventoryDb;User Id=sa;Password=Your_password123;TrustServerCertificate=true
NOTIFICATION_DB_CONNECTION_STRING=Server=notification-db,1433;Database=NotificationDb;User Id=sa;Password=Your_password123;TrustServerCertificate=true
AUTH_DB_CONNECTION_STRING=Server=auth-db,1433;Database=AuthDb;User Id=sa;Password=Your_password123;TrustServerCertificate=true

# Service-to-service endpoints
AUTH_AUTHORITY=http://auth-service-api:8080/
AUTH_TOKEN_ENDPOINT=http://auth-service-api:8080/connect/token
CATALOG_GRPC_URL=http://catalog-service-api:8080
INVENTORY_GRPC_URL=http://inventory-service-api:8080
CATALOG_API_INTERNAL_URL=http://catalog-service-api:8080/
ORDERING_API_INTERNAL_URL=http://ordering-service-api:8080/
INVENTORY_API_INTERNAL_URL=http://inventory-service-api:8080/
NOTIFICATION_API_INTERNAL_URL=http://notification-service-api:8080/
